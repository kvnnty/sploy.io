model Team {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  billingPlan          BillingPlan   @default(free) @map("billing_plan")
  billingStatus        BillingStatus @default(none) @map("billing_status")
  stripeCustomerId     String?       @unique @map("stripe_customer_id")
  stripeSubscriptionId String?       @unique @map("stripe_subscription_id")

  stripeSubscriptionItemAiQueryId         String? @map("stripe_si_ai_query")
  stripeSubscriptionItemAgentRunId        String? @map("stripe_si_agent_run")
  stripeSubscriptionItemActionExecutionId String? @map("stripe_si_action_execution")

  billingPeriodStart DateTime? @map("billing_period_start") @db.Timestamptz(6)
  billingPeriodEnd   DateTime? @map("billing_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")

  preferredByUsers User[]           @relation("PreferredTeam")
  memberships      Membership[]
  ssoConnections   SsoConnection[]
  dataSources      DataSource[]
  authEvents       AuthEvent[]
  invitations      Invitation[]
  activities       TeamActivity[]
  usageEvents      UsageEvent[]
  usageSummaries   UsageSummary[]
  analysisRuns     AnalysisRun[]
  decisionActions  DecisionAction[]
  integration      TeamIntegration?
  teamImports      TeamImport[]

  @@map("teams")
}
