PORT=8080
CORS_ORIGIN=http://localhost:3000

# Clerk secret key (from Clerk Dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_xxxxx

DATABASE_URL=postgresql://postgres:password@localhost:5432/sploy

# --- MVP core (required for Ask / NL-SQL / briefs) ---

# OpenAI — NL→SQL and analysis briefs (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxx

# 32-byte key, base64 — encrypts warehouse passwords and integration tokens
# Generate: openssl rand -base64 32
DATASOURCE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# Optional: dedicated Postgres for materialized CSV datasets (defaults to DATABASE_URL if unset)
# DATASET_DATABASE_URL=postgresql://postgres:password@localhost:5432/sploy_datasets

# --- Object storage (CSV uploads; required for Phase 2 ingest) ---
# From repo root: docker compose -f docker-compose.minio.yml up -d
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sploy
MINIO_USE_SSL=false
# MINIO_PUBLIC_URL=https://cdn.example.com/sploy

# --- Email (report delivery fallback; Resend https://resend.com/api-keys) ---
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=notifications@sploy.io
# APP_URL=http://localhost:3000
# APP_NAME=Sploy

# --- Slack (Phase 4 — https://api.slack.com/apps → Create App → OAuth & Permissions) ---
# Bot scopes: chat:write, channels:read (add channels:join if posting to public channels)
# SLACK_CLIENT_ID=1234567890.1234567890
# SLACK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Redirect URL (configure in Slack app): {APP_URL}/api/integrations/slack/callback
# Optional: default channel ID for scheduled briefs if user does not pick one
# SLACK_DEFAULT_CHANNEL_ID=C0123456789

# --- Scheduled tasks / internal job runner (Phase 5) ---
# Shared secret for POST /internal/jobs/run (cron on VPS or GitHub Actions)
# Generate: openssl rand -hex 32
# JOB_RUNNER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Post-MVP integrations (placeholders; uncomment when building) ---

# Google Sheets OAuth (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Microsoft Teams incoming webhook (per-channel; no global secret)
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# WhatsApp Business Cloud API (https://developers.facebook.com/)
# WHATSAPP_ACCESS_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# Jira Cloud (https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/)
# JIRA_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# JIRA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (billing). Optional in local dev; checkout/portal need STRIPE_SECRET_KEY + base plan price IDs.
# Webhook: POST {API}/api/billing/webhook — raw body required (app uses Nest rawBody).
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/dashboard/settings/billing
