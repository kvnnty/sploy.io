PORT=8080
CORS_ORIGIN=http://localhost:3000

# Clerk secret key (from Clerk Dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_xxxxx

DATABASE_URL=postgresql://postgres:password@localhost:5432/sploy

# Stripe (billing). Optional in local dev; checkout/portal need STRIPE_SECRET_KEY + base plan price IDs.
# Webhook: POST {API}/api/billing/webhook — raw body required (app uses Nest rawBody).
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
# Optional: defaults to {APP_URL}/dashboard/settings/billing
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/dashboard/settings/billing

# MinIO / S3-compatible object storage (optional — file uploads disabled if absent)
# From repo root: docker compose -f docker-compose.minio.yml up -d
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sploy
MINIO_USE_SSL=false
# Public URL prefix for serving uploaded files (defaults to http://endpoint:port/bucket)
# MINIO_PUBLIC_URL=https://cdn.example.com/sploy

# Resend email notifications (optional)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=notifications@sploy.io
# APP_URL=http://localhost:3000
# APP_NAME=Sploy
